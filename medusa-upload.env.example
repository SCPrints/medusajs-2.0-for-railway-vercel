# Copy to medusa-upload.env (gitignored) and fill in real values.
# Run from repo root:
#   .venv-upload/bin/python scripts/rewrite_csv_image_urls_via_medusa_upload.py \
#     --env-file medusa-upload.env \
#     --input syzmik_medusa_import.csv \
#     --output syzmik_medusa_import_medusa_files.csv
#
# Auth: set MEDUSA_ADMIN_COOKIE (typical for Medusa admin on same host) and/or MEDUSA_ADMIN_TOKEN.
# Cookie: DevTools → Network → any /admin/... request → Headers → copy the full "cookie:" value
# (e.g. connect.sid=s%3A...). Paste on ONE line below.

MEDUSA_BACKEND_URL=https://backend-production-6501.up.railway.app
MEDUSA_ADMIN_COOKIE=connect.sid=PASTE_VALUE_FROM_DEVTOOLS_HERE
# MEDUSA_ADMIN_TOKEN=optional-bearer-jwt-if-your-setup-uses-it
