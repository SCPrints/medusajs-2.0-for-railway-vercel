{
  "name": "medusa-2.0-boilerplate-backend",
  "version": "0.0.2",
  "description": "A Prebaked Medusa 2.0 backend",
  "author": "Rasmus Puls",
  "license": "MIT",
  "keywords": [
    "sqlite",
    "postgres",
    "typescript",
    "ecommerce",
    "headless",
    "medusa"
  ],
  "scripts": {
    "build": "npx medusa build && node src/scripts/postBuild.js",
    "seed": "npx medusa exec ./src/scripts/seed.ts",
    "backfill-product-brands": "npx medusa exec ./src/scripts/backfill-product-brand-metadata.ts",
    "update-as-colour-pricing": "npx medusa exec ./src/scripts/update-as-colour-pricing.ts --",
    "trim-as-colour-catalog": "npx medusa exec ./src/scripts/trim-as-colour-catalog-by-allowlist.ts --",
    "trim-syzmik-catalog": "npx medusa exec ./src/scripts/trim-syzmik-catalog-by-allowlist.ts --",
    "trim-ramo-catalog": "npx medusa exec ./src/scripts/trim-ramo-catalog-by-allowlist.ts --",
    "import-dnc-products": "npx medusa exec ./src/scripts/import-dnc-products.ts --",
    "ib": "init-backend",
    "start": "init-backend && cd .medusa/server && npx medusa start --verbose",
    "dev": "npx medusa develop",
    "test": "jest --config jest.config.cjs",
    "email:dev": "email dev --dir=./src/modules/email-notifications/templates --port=3002"
  },
  "dependencies": {
    "@medusajs/admin-sdk": "2.12.1",
    "@medusajs/admin-shared": "2.12.1",
    "@medusajs/cli": "2.12.1",
    "@medusajs/dashboard": "2.12.1",
    "@medusajs/draft-order": "2.12.1",
    "@medusajs/framework": "2.12.1",
    "@medusajs/medusa": "2.12.1",
    "@medusajs/notification-sendgrid": "2.12.1",
    "@medusajs/payment-stripe": "2.12.1",
    "@medusajs/workflow-engine-redis": "2.12.1",
    "@react-email/components": "^1.0.1",
    "@rokmohar/medusa-plugin-meilisearch": "1.3.5",
    "medusajs-launch-utils": "0.0.18",
    "minio": "^8.0.6",
    "pg": "^8.20.0",
    "resend": "4.0.1",
    "sharp": "^0.34.4",
    "ulid": "^2.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@medusajs/test-utils": "2.12.1",
    "@react-email/preview-server": "^5.1.0",
    "@swc/core": "1.5.7",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.25",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "jest": "^29.7.0",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-email": "^5.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^5.4.21"
  },
  "packageManager": "pnpm@9.10.0",
  "engines": {
    "node": "22.x",
    "npm": "10.x"
  }
}